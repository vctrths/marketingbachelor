# Security headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://*.netlify.app; style-src 'self' https://fonts.googleapis.com https://api.fontshare.com 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' https://fonts.gstatic.com https://api.fontshare.com https://cdn.fontshare.com; connect-src 'self' ws: wss:; frame-src 'self' https://www.googletagmanager.com; form-action 'self'; worker-src 'self' blob:; manifest-src 'self'
